{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}
    <h1>User index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Password</th>
                <th>Firstname</th>
                <th>Lastname</th>
                <th>Town</th>
                <th>Cv</th>
                <th>Github</th>
                <th>Linkedin</th>
                <th>Portfolio</th>
                <th>ProfilePicture</th>
                <th>Description</th>
                <th>Pricing</th>
                <th>CreatedAt</th>
                <th>UpdateAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
                <td>{{ user.password }}</td>
                <td>{{ user.firstname }}</td>
                <td>{{ user.lastname }}</td>
                <td>{{ user.town }}</td>
                <td>{{ user.cv }}</td>
                <td>{{ user.github }}</td>
                <td>{{ user.linkedin }}</td>
                <td>{{ user.portfolio }}</td>
                <td>{{ user.profilePicture }}</td>
                <td>{{ user.description }}</td>
                <td>{{ user.pricing }}</td>
                <td>{{ user.CreatedAt ? user.CreatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ user.updateAt ? user.updateAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_backoffice_user_show', {'id': user.id}) }}">show</a>
                    <a href="{{ path('app_backoffice_user_edit', {'id': user.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="17">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_backoffice_user_new') }}">Create new</a>
{% endblock %}
